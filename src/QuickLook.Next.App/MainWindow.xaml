<Window
    x:Class="QuickLook.Next.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QuickLook.Next.App">
    <!-- Transparent root so the window's Mica/Acrylic backdrop shows through (margins & image letterbox). -->
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <ResourceDictionary>
                <Style x:Key="ListingHeaderButtonStyle" TargetType="Button">
                    <Setter Property="MinHeight" Value="28" />
                    <Setter Property="Padding" Value="8,0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="CornerRadius" Value="4" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                </Style>
                <Style x:Key="PreviewIconButtonStyle" TargetType="Button">
                    <Setter Property="Width" Value="40" />
                    <Setter Property="Height" Value="40" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="CornerRadius" Value="6" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                </Style>
                <Style x:Key="PreviewIconToggleButtonStyle" TargetType="ToggleButton">
                    <Setter Property="Width" Value="40" />
                    <Setter Property="Height" Value="40" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="CornerRadius" Value="6" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                </Style>
                <Style x:Key="PreviewZoomPresetButtonStyle" TargetType="Button">
                    <Setter Property="Width" Value="46" />
                    <Setter Property="Height" Value="40" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="CornerRadius" Value="16" />
                    <Setter Property="Background" Value="{ThemeResource PreviewHeroSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{ThemeResource PreviewSurfaceBorderBrush}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                </Style>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="PreviewSurfaceBrush" Color="#F8FFFFFF" />
                        <SolidColorBrush x:Key="PreviewSurfaceBorderBrush" Color="#18000000" />
                        <SolidColorBrush x:Key="PreviewHeroSurfaceBrush" Color="#0A000000" />
                        <SolidColorBrush x:Key="PreviewFloatingSurfaceBrush" Color="#EBFFFFFF" />
                        <SolidColorBrush x:Key="ExplorerListingSurfaceBrush" Color="#F7FFFFFF" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="PreviewSurfaceBrush" Color="#D91F1F1F" />
                        <SolidColorBrush x:Key="PreviewSurfaceBorderBrush" Color="#24FFFFFF" />
                        <SolidColorBrush x:Key="PreviewHeroSurfaceBrush" Color="#12FFFFFF" />
                        <SolidColorBrush x:Key="PreviewFloatingSurfaceBrush" Color="#E61F1F1F" />
                        <SolidColorBrush x:Key="ExplorerListingSurfaceBrush" Color="#D41F1F1F" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="HighContrast">
                        <SolidColorBrush x:Key="PreviewSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
                        <SolidColorBrush x:Key="PreviewSurfaceBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                        <SolidColorBrush x:Key="PreviewHeroSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
                        <SolidColorBrush x:Key="PreviewFloatingSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
                        <SolidColorBrush x:Key="ExplorerListingSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>
            </ResourceDictionary>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar"
              x:Uid="AppTitleBar"
              Grid.Row="0"
              Height="52"
              Background="Transparent"
              ColumnSpacing="12"
              Padding="14,0,144,0"
              AutomationProperties.Name="Preview title bar">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE945;"
                          FontSize="17"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock x:Uid="AppBrandText"
                           Text="QuickLook Next"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>
            <Border Grid.Column="1"
                    Width="1"
                    Height="18"
                    VerticalAlignment="Center"
                    Background="{ThemeResource PreviewSurfaceBorderBrush}" />
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                <TextBlock x:Name="PreviewTitleText"
                           Text="QuickLook Next"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock x:Name="PreviewMetaText"
                           Text="Ready"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <Border Grid.Column="3"
                    MinWidth="52"
                    Height="26"
                    Padding="10,0"
                    VerticalAlignment="Center"
                    CornerRadius="13"
                    Background="{ThemeResource PreviewHeroSurfaceBrush}"
                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                    BorderThickness="1">
                <TextBlock x:Name="PreviewKindPillText"
                           Text="READY"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>
        </Grid>

        <!-- Content Area -->
        <Grid x:Name="PreviewContentHost"
              x:Uid="PreviewContentHost"
              Grid.Row="1"
              AutomationProperties.Name="Preview content">
            <Border x:Name="PreviewRoot"
                    x:Uid="PreviewRoot"
                    Margin="14,0,14,14"
                    Background="{ThemeResource PreviewHeroSurfaceBrush}"
                    AutomationProperties.Name="Image preview surface" />
            <Border x:Name="AnimatedImagePreviewRoot"
                    x:Uid="AnimatedImagePreviewRoot"
                    Visibility="Collapsed"
                    Margin="14,0,14,14"
                    Background="{ThemeResource PreviewHeroSurfaceBrush}"
                    AutomationProperties.Name="Animated image preview">
                <Grid>
                    <Image x:Name="AnimatedImagePreviewImage"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Fill"
                           AutomationProperties.Name="Animated image content" />
                </Grid>
            </Border>
            <ScrollViewer x:Name="PdfScrollViewer"
                          x:Uid="PdfScrollViewer"
                          Visibility="Collapsed"
                          Margin="14,0,14,14"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="{ThemeResource PreviewSurfaceBrush}"
                          BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          AutomationProperties.Name="PDF preview pages">
                <StackPanel x:Name="PdfPagesPanel"
                            HorizontalAlignment="Center"
                            Padding="0,16,0,16"
                            Spacing="16" />
            </ScrollViewer>
            <Border x:Name="PdfPagerBar"
                    x:Uid="PdfPagerBar"
                    Visibility="Collapsed"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="26,12,0,0"
                    Padding="6"
                    Background="{ThemeResource PreviewFloatingSurfaceBrush}"
                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    AutomationProperties.Name="PDF page navigation">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button x:Name="PreviousPdfPageButton"
                            x:Uid="PreviousPdfPageButton"
                            Click="OnPreviousPdfPageClick"
                            Style="{StaticResource PreviewIconButtonStyle}"
                            AutomationProperties.Name="Previous PDF page">
                        <FontIcon Glyph="&#xE76B;" FontSize="14" />
                    </Button>
                    <TextBlock x:Name="PdfPageIndicatorText"
                               MinWidth="62"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="1 / 1"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               AutomationProperties.Name="Current PDF page"
                               AutomationProperties.LiveSetting="Polite" />
                    <Button x:Name="NextPdfPageButton"
                            x:Uid="NextPdfPageButton"
                            Click="OnNextPdfPageClick"
                            Style="{StaticResource PreviewIconButtonStyle}"
                            AutomationProperties.Name="Next PDF page">
                        <FontIcon Glyph="&#xE76C;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Border>
            <Border x:Name="MarkdownOutlinePanel"
                    x:Uid="MarkdownOutlinePanel"
                    Visibility="Collapsed"
                    Width="188"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Margin="14,0,0,14"
                    Padding="8"
                    Background="{ThemeResource PreviewSurfaceBrush}"
                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    AutomationProperties.Name="Markdown headings">
                <ListView x:Name="MarkdownOutlineList"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          AutomationProperties.Name="Markdown heading navigation">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}"
                                       Margin="{Binding Margin}"
                                       FontSize="{Binding FontSize}"
                                       FontWeight="{Binding FontWeight}"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
            <Border x:Name="TextPreviewContainer"
                    x:Uid="TextPreviewContainer"
                    Visibility="Collapsed"
                    Margin="14,0,14,14"
                    Background="{ThemeResource PreviewSurfaceBrush}"
                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    AutomationProperties.Name="Text preview">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid x:Name="TextHeroPanel"
                          Grid.Row="0"
                          Visibility="Collapsed"
                          ColumnSpacing="14"
                          Margin="24,24,24,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="TextHeroFrame"
                                Width="64"
                                Height="64"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                BorderThickness="1"
                                Background="{ThemeResource PreviewHeroSurfaceBrush}">
                            <Image x:Name="TextHeroImage"
                                   Stretch="Uniform"
                                   Margin="6" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                            <TextBlock x:Name="TextHeroTitle"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="TextHeroSubtitle"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                    <ScrollViewer x:Name="TextScrollViewer"
                                  x:Uid="TextScrollViewer"
                                  Grid.Row="1"
                                  Visibility="Visible"
                                  Padding="24"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="14">
                            <RichTextBlock x:Name="TextPreviewBlock"
                                           x:Uid="TextPreviewBlock"
                                           IsTextSelectionEnabled="True"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontSize="14"
                                           FontFamily="Segoe UI"
                                           TextWrapping="Wrap"
                                           MaxWidth="980"
                                           AutomationProperties.Name="Text preview content" />
                        </StackPanel>
                    </ScrollViewer>
                    <ListView x:Name="TextListView"
                              x:Uid="TextListView"
                              Grid.Row="1"
                              Visibility="Collapsed"
                              Padding="24"
                              SelectionMode="Extended"
                              IsItemClickEnabled="False"
                              ShowsScrollingPlaceholders="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:TextLineItem">
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding LineNumber}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="13"
                                               FontFamily="Cascadia Mono, Consolas"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,16,0"
                                               VerticalAlignment="Top" />
                                    <ContentControl Content="{Binding Content}" Grid.Column="1" VerticalAlignment="Top" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

            <Border x:Name="TextToolbar"
                    Grid.Row="1"
                    Margin="0,12,24,0"
                    Canvas.ZIndex="10"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <StackPanel x:Name="TextFindPanel"
                                Visibility="Collapsed"
                                Orientation="Horizontal"
                                Spacing="4">
                        <TextBox x:Name="TextFindBox"
                                 Width="220"
                                 MinHeight="40"
                                 PlaceholderText="Find"
                                 TextChanged="OnTextFindTextChanged"
                                 KeyDown="OnTextFindKeyDown"
                                 AutomationProperties.Name="Find in preview" />
                        <TextBlock x:Name="TextFindCountText"
                                   MinWidth="54"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   AutomationProperties.LiveSetting="Polite" />
                        <Button Width="40" Height="40"
                                Click="OnTextFindPreviousClick"
                                AutomationProperties.Name="Previous match">
                            <FontIcon Glyph="&#xE70E;" FontSize="14" />
                        </Button>
                        <Button Width="40" Height="40"
                                Click="OnTextFindNextClick"
                                AutomationProperties.Name="Next match">
                            <FontIcon Glyph="&#xE70D;" FontSize="14" />
                        </Button>
                        <Button Width="40" Height="40"
                                Click="OnTextFindCloseClick"
                                AutomationProperties.Name="Close search">
                            <FontIcon Glyph="&#xE711;" FontSize="14" />
                        </Button>
                    </StackPanel>
                    <ToggleButton x:Name="TextWordWrapButton" 
                                   Width="40" Height="40"
                                   ToolTipService.ToolTip="Toggle Word Wrap"
                                   Padding="6" Background="Transparent" BorderThickness="0"
                                   AutomationProperties.Name="Toggle word wrap"
                                   Click="TextWordWrapButton_Click">
                        <FontIcon Glyph="&#xE8B3;" FontSize="14"/>
                    </ToggleButton>
                    <ToggleButton x:Name="TextLineNumbersButton"
                                  Visibility="Collapsed"
                                  IsChecked="True"
                                  ToolTipService.ToolTip="Toggle Line Numbers"
                                  Padding="6" Background="Transparent" BorderThickness="0"
                                  Click="TextLineNumbersButton_Click">
                        <FontIcon Glyph="&#xE8EF;" FontSize="14"/>
                    </ToggleButton>
                    <Button x:Name="TextSearchButton"
                            Width="40" Height="40"
                            ToolTipService.ToolTip="Search (Ctrl+F)"
                            Padding="6" Background="Transparent" BorderThickness="0"
                            AutomationProperties.Name="Search text"
                            Click="TextSearchButton_Click">
                        <FontIcon Glyph="&#xE721;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
            <ScrollViewer x:Name="TableScrollViewer"
                          x:Uid="TableScrollViewer"
                          Visibility="Collapsed"
                          Margin="14,0,14,14"
                          Padding="20"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="{ThemeResource PreviewSurfaceBrush}"
                          BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          AutomationProperties.Name="Delimited table preview">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="48"
                                Height="48"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                BorderThickness="1"
                                Background="{ThemeResource PreviewHeroSurfaceBrush}">
                            <FontIcon Glyph="&#xE80A;"
                                      FontSize="22"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="3">
                            <TextBlock x:Name="TableTitleText"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="TableSummaryText"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                    <Border Background="{ThemeResource PreviewFloatingSurfaceBrush}"
                            BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            HorizontalAlignment="Left">
                        <Canvas x:Name="TableGrid"
                                AutomationProperties.Name="Delimited table cells" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
            <ScrollViewer x:Name="OfficeScrollViewer"
                          x:Uid="OfficeScrollViewer"
                          Visibility="Collapsed"
                          Margin="14,0,14,14"
                          Padding="20"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="{ThemeResource PreviewSurfaceBrush}"
                          BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          AutomationProperties.Name="Office document preview">
                <StackPanel x:Name="OfficePagesPanel"
                            HorizontalAlignment="Center"
                            Spacing="18" />
            </ScrollViewer>
            <MediaPlayerElement x:Name="MediaPreviewElement"
                                x:Uid="MediaPreviewElement"
                                Visibility="Collapsed"
                                Margin="14,0,14,14"
                                AreTransportControlsEnabled="True"
                                AutoPlay="True"
                                Background="Transparent"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                AutomationProperties.Name="Media preview player" />
            <Border x:Name="PreviewInfoRail"
                    x:Uid="PreviewInfoRail"
                    Visibility="Collapsed"
                    Width="246"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Margin="0,0,14,82"
                    Padding="14"
                    Background="{ThemeResource PreviewFloatingSurfaceBrush}"
                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    AutomationProperties.Name="Preview details">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="8" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="InfoTabButton"
                                    x:Uid="InfoTabButton"
                                    Height="50"
                                    Click="OnPreviewInfoTabClick"
                                    CornerRadius="6"
                                    Background="{ThemeResource PreviewHeroSurfaceBrush}"
                                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                    BorderThickness="1"
                                    AutomationProperties.Name="Show file information">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE946;" FontSize="15" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    <TextBlock x:Uid="InfoTabText" Text="Info" FontSize="10" FontWeight="SemiBold" />
                                    <Border x:Name="InfoTabUnderline" Width="24" Height="2" CornerRadius="1" Background="{ThemeResource AccentFillColorDefaultBrush}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ExifTabButton"
                                    x:Uid="ExifTabButton"
                                    Grid.Column="1"
                                    Height="50"
                                    Click="OnPreviewExifTabClick"
                                    CornerRadius="6"
                                    Background="{ThemeResource PreviewHeroSurfaceBrush}"
                                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                    BorderThickness="0"
                                    AutomationProperties.Name="Show EXIF information">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE713;" FontSize="15" />
                                    <TextBlock x:Uid="ExifTabText" Text="EXIF" FontSize="10" />
                                    <Border x:Name="ExifTabUnderline" Width="24" Height="2" CornerRadius="1" Background="{ThemeResource AccentFillColorDefaultBrush}" Visibility="Collapsed" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="MoreTabButton"
                                    x:Uid="MoreTabButton"
                                    Grid.Column="2"
                                    Height="50"
                                    Click="OnPreviewMoreTabClick"
                                    CornerRadius="6"
                                    Background="{ThemeResource PreviewHeroSurfaceBrush}"
                                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                    BorderThickness="0"
                                    AutomationProperties.Name="Show more preview actions">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE712;" FontSize="15" />
                                    <TextBlock x:Uid="MoreTabText" Text="More" FontSize="10" />
                                    <Border x:Name="MoreTabUnderline" Width="24" Height="2" CornerRadius="1" Background="{ThemeResource AccentFillColorDefaultBrush}" Visibility="Collapsed" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource PreviewSurfaceBorderBrush}" />
                    </StackPanel>
                    <StackPanel x:Name="InfoDetailsPanel" Grid.Row="1" Spacing="12">
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="DimensionsLabel" Text="Dimensions" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PreviewDimensionsText" Text="-" FontSize="13" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="SizeLabel" Text="Size" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PreviewSizeText" Text="-" FontSize="13" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="TypeLabel" Text="Type" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PreviewTypeText" Text="-" FontSize="13" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="ModifiedLabel" Text="Modified" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PreviewModifiedText" Text="-" FontSize="13" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="PathLabel" Text="Path" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PreviewPathText" Text="-" FontSize="12" TextWrapping="WrapWholeWords" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <Grid x:Name="ExifDetailsPanel"
                          Grid.Row="1"
                          Visibility="Collapsed">
                        <StackPanel x:Name="ExifEmptyPanel"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch"
                                    Spacing="8">
                            <FontIcon Glyph="&#xE9CE;"
                                      FontSize="28"
                                      HorizontalAlignment="Center"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ExifUnavailableText"
                                       x:Uid="ExifUnavailableText"
                                       Text="No EXIF data"
                                       TextAlignment="Center"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ScrollViewer x:Name="ExifScrollViewer"
                                      Visibility="Collapsed"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      AutomationProperties.Name="EXIF metadata">
                            <StackPanel Spacing="12">
                                <StackPanel x:Name="ExifDetailsList" Spacing="12" />
                                <Button x:Name="ExifGoogleMapsButton"
                                        Visibility="Collapsed"
                                        Height="34"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="6"
                                        Background="{ThemeResource PreviewHeroSurfaceBrush}"
                                        BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                        BorderThickness="1"
                                        Padding="10,0"
                                        Click="OnOpenExifLocationInMapsClick"
                                        AutomationProperties.Name="Open image location in Google Maps">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE707;" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        <TextBlock x:Uid="ExifGoogleMapsText" Text="Open in Google Maps" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                    <StackPanel x:Name="MoreActionsPanel"
                                Grid.Row="1"
                                Visibility="Collapsed"
                                Spacing="8">
                        <Button x:Uid="CopyPreviewFileButton"
                                Height="36"
                                HorizontalAlignment="Stretch"
                                Click="OnCopyPreviewFileClick"
                                CornerRadius="6"
                                Background="{ThemeResource PreviewHeroSurfaceBrush}"
                                BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                BorderThickness="1"
                                AutomationProperties.Name="Copy previewed file">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                <TextBlock x:Uid="CopyPreviewFileText" Text="Copy file" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:Uid="OpenPreviewFileButton"
                                Height="36"
                                HorizontalAlignment="Stretch"
                                Click="OnOpenPreviewFileClick"
                                CornerRadius="6"
                                Background="Transparent"
                                BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                BorderThickness="1"
                                AutomationProperties.Name="Open previewed file">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                                <TextBlock x:Uid="OpenPreviewFileText" Text="Open file" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:Uid="RevealPreviewFileButton"
                                Height="36"
                                HorizontalAlignment="Stretch"
                                Click="OnOpenFileLocationClick"
                                CornerRadius="6"
                                Background="Transparent"
                                BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                BorderThickness="1"
                                AutomationProperties.Name="Reveal previewed file in File Explorer">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE838;" FontSize="14" />
                                <TextBlock x:Uid="RevealPreviewFileText" Text="Reveal in Explorer" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button x:Uid="DeletePreviewFileButton"
                                Height="36"
                                HorizontalAlignment="Stretch"
                                Click="OnDeletePreviewFileClick"
                                CornerRadius="6"
                                Background="Transparent"
                                BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                BorderThickness="1"
                                AutomationProperties.Name="Move previewed file to Recycle Bin">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock x:Uid="DeletePreviewFileText" Text="Delete file" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <Button x:Name="InfoOpenFileLocationButton"
                            x:Uid="OpenFileLocationButton"
                            Grid.Row="2"
                            Height="36"
                            HorizontalAlignment="Stretch"
                            Click="OnOpenFileLocationClick"
                            CornerRadius="6"
                            Background="{ThemeResource PreviewHeroSurfaceBrush}"
                            BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                            BorderThickness="1"
                            AutomationProperties.Name="Open file location">
                        <TextBlock x:Uid="OpenFileLocationText"
                                   Text="Open file location"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Button>
                </Grid>
            </Border>
            <Border x:Name="ImagePreviewToolbar"
                    x:Uid="ImagePreviewToolbar"
                    Visibility="Collapsed"
                    Height="58"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Margin="14,0,260,14"
                    Padding="12,0"
                    Background="{ThemeResource PreviewFloatingSurfaceBrush}"
                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    AutomationProperties.Name="Image preview toolbar">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button x:Uid="ZoomOutButton"
                                Click="OnImageZoomOutClick"
                                Style="{StaticResource PreviewIconButtonStyle}"
                                AutomationProperties.Name="Zoom out">
                            <FontIcon Glyph="&#xE71F;" FontSize="15" />
                        </Button>
                        <TextBlock x:Name="ImageZoomText"
                                   x:Uid="ImageZoomText"
                                   Text="Fit"
                                   MinWidth="48"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   AutomationProperties.Name="Current zoom level" />
                        <Button x:Uid="ZoomInButton"
                                Click="OnImageZoomInClick"
                                Style="{StaticResource PreviewIconButtonStyle}"
                                AutomationProperties.Name="Zoom in">
                            <FontIcon Glyph="&#xE8A3;" FontSize="15" />
                        </Button>
                        <Button x:Uid="FitToWindowButton"
                                Click="OnImageZoomFitClick"
                                Style="{StaticResource PreviewIconButtonStyle}"
                                AutomationProperties.Name="Fit to window">
                            <FontIcon Glyph="&#xE740;" FontSize="15" />
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                        <Button x:Uid="ZoomPreset50Button" Tag="0.5" Click="OnImageZoomPresetClick" Style="{StaticResource PreviewZoomPresetButtonStyle}" AutomationProperties.Name="Set zoom to 50 percent">
                            <TextBlock x:Uid="ZoomPreset50Text" Text="50%" FontSize="12" />
                        </Button>
                        <Button x:Uid="ZoomPreset100Button" Width="52" Tag="1" Click="OnImageZoomPresetClick" Style="{StaticResource PreviewZoomPresetButtonStyle}" BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" BorderThickness="1" AutomationProperties.Name="Set zoom to 100 percent">
                            <TextBlock x:Uid="ZoomPreset100Text" Text="100%" FontSize="12" />
                        </Button>
                        <Button x:Uid="ZoomPreset200Button" Tag="2" Click="OnImageZoomPresetClick" Style="{StaticResource PreviewZoomPresetButtonStyle}" AutomationProperties.Name="Set zoom to 200 percent">
                            <TextBlock x:Uid="ZoomPreset200Text" Text="200%" FontSize="12" />
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ToggleButton x:Name="CompactInfoRailToggle"
                                      Visibility="Collapsed"
                                      Click="OnCompactInfoRailToggleClick"
                                      Style="{StaticResource PreviewIconToggleButtonStyle}">
                            <FontIcon Glyph="&#xE946;" FontSize="15" />
                        </ToggleButton>
                        <Button x:Name="ImageAnimationPlaybackButton"
                                Visibility="Collapsed"
                                Click="OnImageAnimationPlaybackClick"
                                Style="{StaticResource PreviewIconButtonStyle}">
                            <FontIcon x:Name="ImageAnimationPlaybackIcon" Glyph="&#xE769;" FontSize="15" />
                        </Button>
                        <Button x:Uid="ActualSizeButton"
                                Click="OnImageActualSizeClick"
                                Style="{StaticResource PreviewIconButtonStyle}"
                                AutomationProperties.Name="Show image at actual size">
                            <FontIcon Glyph="&#xE8A9;" FontSize="15" />
                        </Button>
                        <Button x:Uid="ResetViewButton"
                                Click="OnImageZoomFitClick"
                                Style="{StaticResource PreviewIconButtonStyle}"
                                AutomationProperties.Name="Reset view">
                            <FontIcon Glyph="&#xE72C;" FontSize="15" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <Border x:Name="ImageFilmstrip"
                    x:Uid="ImageFilmstrip"
                    Visibility="Collapsed"
                    Height="76"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Margin="14,0,260,78"
                    Padding="10,0"
                    Background="{ThemeResource PreviewFloatingSurfaceBrush}"
                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    AutomationProperties.Name="Adjacent image thumbnails">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Uid="PreviousImageButton"
                            Click="OnPreviousImageClick"
                            Style="{StaticResource PreviewIconButtonStyle}"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Previous image">
                        <FontIcon Glyph="&#xE76B;" FontSize="15" />
                    </Button>
                    <ListView x:Name="ImageFilmstripList"
                              Grid.Column="1"
                              Height="64"
                              Padding="0"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              IsSwipeEnabled="False"
                              ScrollViewer.HorizontalScrollMode="Enabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.VerticalScrollMode="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ItemClick="OnImageFilmstripItemClick"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="Adjacent images">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                 <Border Width="70"
                                         Height="54"
                                        Margin="4"
                                        CornerRadius="6"
                                        Background="{ThemeResource PreviewHeroSurfaceBrush}"
                                         BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                         BorderThickness="1"
                                         AutomationProperties.Name="{Binding Name}"
                                         ToolTipService.ToolTip="{Binding Name}">
                                    <Image Source="{Binding Thumbnail, Mode=OneWay}"
                                           Margin="3"
                                           Stretch="Uniform" />
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button x:Uid="NextImageButton"
                            Grid.Column="2"
                            Click="OnNextImageClick"
                            Style="{StaticResource PreviewIconButtonStyle}"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Next image">
                        <FontIcon Glyph="&#xE76C;" FontSize="15" />
                    </Button>
                </Grid>
            </Border>
            <Border x:Name="ListingPanel"
                    x:Uid="ListingPanel"
                    Visibility="Collapsed"
                    Margin="14,0,14,14"
                    Padding="18"
                    Background="{ThemeResource ExplorerListingSurfaceBrush}"
                    BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    AutomationProperties.Name="Folder or archive preview">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="ListingHeroFrame"
                                Visibility="Collapsed"
                                Width="48"
                                Height="48"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                BorderThickness="1"
                                Background="{ThemeResource PreviewHeroSurfaceBrush}">
                            <Image x:Name="ListingHeroImage"
                                   Stretch="Uniform"
                                   Margin="5" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                            <TextBlock x:Name="ListingTitle"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="ListingSummary"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="ListingBreadcrumbPanel"
                                Grid.Row="1"
                                Orientation="Horizontal"
                                Spacing="4"
                                x:Uid="ListingBreadcrumbPanel"
                                AutomationProperties.Name="Listing path breadcrumbs" />

                    <ScrollViewer Grid.Row="2"
                                  Grid.RowSpan="2"
                                  HorizontalScrollMode="Enabled"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled"
                                  ZoomMode="Disabled">
                        <Grid MinWidth="692">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Padding="8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" MinWidth="220" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ListingNameHeader" x:Uid="ListingNameHeader" Grid.Column="1" Tag="name" Click="OnListingSortClick" HorizontalAlignment="Left" Style="{StaticResource ListingHeaderButtonStyle}" AutomationProperties.Name="Sort by name" />
                                <Button x:Name="ListingModifiedHeader" x:Uid="ListingModifiedHeader" Grid.Column="2" Tag="modified" Click="OnListingSortClick" HorizontalAlignment="Left" Style="{StaticResource ListingHeaderButtonStyle}" AutomationProperties.Name="Sort by modified date" />
                                <Button x:Name="ListingTypeHeader" x:Uid="ListingTypeHeader" Grid.Column="3" Tag="type" Click="OnListingSortClick" HorizontalAlignment="Left" Style="{StaticResource ListingHeaderButtonStyle}" AutomationProperties.Name="Sort by type" />
                                <Button x:Name="ListingSizeHeader" x:Uid="ListingSizeHeader" Grid.Column="4" Tag="size" Click="OnListingSortClick" HorizontalAlignment="Right" HorizontalContentAlignment="Right" Style="{StaticResource ListingHeaderButtonStyle}" AutomationProperties.Name="Sort by size" />
                            </Grid>

                    <ListView x:Name="ListingListView"
                              x:Uid="ListingListView"
                              Grid.Row="1"
                              IsItemClickEnabled="True"
                              ItemClick="OnListingItemClick"
                              DoubleTapped="OnListingListViewDoubleTapped"
                              KeyDown="OnListingListViewKeyDown"
                              SelectionMode="Single"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollMode="Enabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              AutomationProperties.Name="Preview listing">
                        <ListView.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.ThemeDictionaries>
                                    <ResourceDictionary x:Key="Light">
                                        <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#0A000000" />
                                        <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="#12000000" />
                                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#CCE8FF" />
                                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#BBDDFF" />
                                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#A7D3F6" />
                                        <SolidColorBrush x:Key="ListViewItemFocusBorderBrush" Color="#8A000000" />
                                    </ResourceDictionary>
                                    <ResourceDictionary x:Key="Dark">
                                        <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="#12FFFFFF" />
                                        <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="#1FFFFFFF" />
                                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#244E78" />
                                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#2B5D8F" />
                                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#346CA3" />
                                        <SolidColorBrush x:Key="ListViewItemFocusBorderBrush" Color="#99FFFFFF" />
                                    </ResourceDictionary>
                                </ResourceDictionary.ThemeDictionaries>
                            </ResourceDictionary>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,1,0,1" />
                                <Setter Property="MinHeight" Value="40" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="40" Padding="8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" MinWidth="220" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0"
                                          Width="22"
                                          Height="22"
                                          VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Glyph}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="15" />
                                        <Image Width="18"
                                               Height="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Source="{Binding IconSource, Mode=OneWay}" />
                                    </Grid>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ModifiedDisplay}"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding TypeDisplay}"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding SizeDisplay}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
            <Border x:Name="StatusBar"
                    Visibility="Collapsed"
                    VerticalAlignment="Top" HorizontalAlignment="Center"
                    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                    CornerRadius="0,0,8,8" Padding="12,3">
                <TextBlock x:Name="StatusText" Text=""
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           AutomationProperties.LiveSetting="Polite" />
            </Border>
        </Grid>

        <ProgressRing x:Name="LoadingRing"
                      x:Uid="LoadingRing"
                      Grid.Row="1"
                      Visibility="Collapsed"
                      IsActive="False"
                      Width="32"
                      Height="32"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       AutomationProperties.Name="Loading preview"
                       AutomationProperties.LiveSetting="Polite" />

        <StackPanel x:Name="ErrorPanel"
                    x:Uid="ErrorPanel"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    AutomationProperties.Name="Preview error">
            <FontIcon Glyph="&#xE783;"
                      FontSize="36"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock x:Name="ErrorText"
                       x:Uid="ErrorText"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="420"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="13"
                        AutomationProperties.Name="Preview error message"
                        AutomationProperties.LiveSetting="Assertive" />
            <StackPanel x:Name="ErrorActionsPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="8">
                <Button x:Name="ErrorRetryButton"
                        x:Uid="ErrorRetryButton"
                        Height="34"
                        Padding="14,0"
                        CornerRadius="6"
                        Background="{ThemeResource PreviewHeroSurfaceBrush}"
                        BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                        BorderThickness="1"
                        Click="OnRetryPreviewClick">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock Text="Try again" FontSize="12" />
                    </StackPanel>
                </Button>
                <Button x:Name="ErrorOpenFileButton"
                        x:Uid="ErrorOpenFileButton"
                        Height="34"
                        Padding="14,0"
                        CornerRadius="6"
                        Background="{ThemeResource PreviewHeroSurfaceBrush}"
                        BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                        BorderThickness="1"
                        Click="OnOpenPreviewFileClick">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                        <TextBlock x:Uid="ErrorOpenFileText" Text="Open file" FontSize="12" />
                    </StackPanel>
                </Button>
                <Button x:Name="ErrorRevealFileButton"
                        x:Uid="ErrorRevealFileButton"
                        Height="34"
                        Padding="14,0"
                        CornerRadius="6"
                        Background="Transparent"
                        BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                        BorderThickness="1"
                        Click="OnOpenFileLocationClick">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE838;" FontSize="14" />
                        <TextBlock x:Uid="ErrorRevealFileText" Text="Reveal in Explorer" FontSize="12" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
