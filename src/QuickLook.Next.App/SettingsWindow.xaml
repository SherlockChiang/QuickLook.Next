<Window
    x:Class="QuickLook.Next.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" SizeChanged="OnContentSizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBar" Height="48" Padding="16,0,140,0">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE713;" FontSize="16" />
                <TextBlock x:Name="TitleBarText" Style="{StaticResource BodyStrongTextBlockStyle}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="ContentPanel" MaxWidth="720" Padding="36,20,36,32" HorizontalAlignment="Stretch">
                <StackPanel Spacing="18">
                    <TextBlock x:Name="SettingsHeading" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="GeneralHeading" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock x:Name="GeneralDescription" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="18,14">
                        <Grid x:Name="LanguageSettingGrid" ColumnSpacing="20" RowSpacing="10">
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                <TextBlock x:Name="AutoStartTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="AutoStartDescription" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch x:Name="AutoStartToggle"
                                          Grid.Column="1"
                                          MinHeight="40"
                                          AutomationProperties.LabeledBy="{x:Bind AutoStartTitle}"
                                          Toggled="OnAutoStartToggled" />
                        </Grid>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="18,14">
                        <Grid x:Name="AnimationSettingGrid" ColumnSpacing="20" RowSpacing="10">
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                <TextBlock x:Name="LanguageTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="LanguageDescription" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox x:Name="LanguageCombo"
                                      Grid.Column="1"
                                      MinHeight="40"
                                      HorizontalAlignment="Stretch"
                                      AutomationProperties.LabeledBy="{x:Bind LanguageTitle}"
                                      SelectionChanged="OnLanguageSelectionChanged">
                                <ComboBoxItem x:Name="SystemLanguageItem" Tag="system" />
                                <ComboBoxItem Content="English" Tag="en-US" />
                                <ComboBoxItem Content="简体中文" Tag="zh-CN" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="18,14">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                <TextBlock x:Name="AnimationTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="AnimationDescription" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox x:Name="AnimationCombo" Grid.Column="1" MinHeight="40" HorizontalAlignment="Stretch"
                                      AutomationProperties.LabeledBy="{x:Bind AnimationTitle}"
                                      SelectionChanged="OnAnimationSelectionChanged">
                                <ComboBoxItem x:Name="SystemAnimationItem" Tag="system" />
                                <ComboBoxItem x:Name="AlwaysAnimateItem" Tag="always" />
                                <ComboBoxItem x:Name="StillAnimationItem" Tag="still" />
                            </ComboBox>
                        </Grid>
                    </Border>

                    <InfoBar x:Name="RestartInfo" Severity="Informational" IsOpen="False" IsClosable="True" />

                    <StackPanel Spacing="4" Margin="0,6,0,0">
                        <TextBlock x:Name="AboutHeading" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock x:Name="AboutDescription" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="15">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <Image x:Name="AppIcon" Width="48" Height="48" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="QuickLook Next" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock x:Name="VersionText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <TextBlock x:Name="ProjectSourceText" TextWrapping="Wrap" />
                            <Button x:Name="HelpButton" Click="OnHelpClick" HorizontalAlignment="Left">
                                <TextBlock x:Name="HelpButtonText" />
                            </Button>
                            <StackPanel x:Name="ProjectLinksPanel" Orientation="Horizontal" Spacing="10">
                                <Button x:Name="GitHubButton" Click="OnGitHubClick">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                        <TextBlock x:Name="GitHubButtonText" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ReleasesButton" Click="OnReleasesClick">
                                    <TextBlock x:Name="ReleasesButtonText" />
                                </Button>
                            </StackPanel>
                            <TextBlock x:Name="LicenseText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
